# Copy this file to .env and adjust as needed. Never commit the real .env.

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=job_scheduler

# Used when running api/worker outside Docker (e.g. local `npm run dev`)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/job_scheduler

# Auth
JWT_SECRET=changeme

# API
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Worker timing (all in ms)
HEARTBEAT_INTERVAL_MS=10000
REAPER_INTERVAL_MS=15000
REAPER_STALE_THRESHOLD_MS=30000
POLL_INTERVAL_MS=1000
DRAIN_TIMEOUT_MS=25000
WORKER_CONCURRENCY=5

# Web
VITE_API_URL=http://localhost:3000
